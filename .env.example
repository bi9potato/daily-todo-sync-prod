# 这是占位模板，不要写真实密码。

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@host:5432/database
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://example.com
TZ=Asia/Shanghai

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=sender@example.com
EMAIL_HOST_PASSWORD=app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Daily Todo <sender@example.com>
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_RESEND_SECONDS=60

GOOGLE_CALENDAR_CLIENT_ID=google-oauth-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=google-oauth-client-secret
GOOGLE_AUTH_REDIRECT_URI=https://example.com/api/auth/google/callback
ANDROID_GOOGLE_AUTH_RETURN_URL=daily-todo://auth/google

APP_HOST=68.183.180.19.sslip.io
APP_IP=68.183.180.19

VITE_API_BASE_URL=/api
