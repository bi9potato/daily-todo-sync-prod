{
  "expo": {
    "name": "Daily Todo",
    "slug": "daily-todo-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "daily-todo",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/app-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.dailytodosync.app"
    },
    "android": {
      "package": "com.dailytodosync.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFEFA",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFEFA",
          "image": "./assets/images/app-icon.png",
          "imageWidth": 112,
          "android": {
            "image": "./assets/images/app-icon.png",
            "imageWidth": 112
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "允许 Daily Todo 在你主动开启足迹记录后持续记录行走路线。",
          "locationWhenInUsePermission": "允许 Daily Todo 获取当前位置并为任务记录地点。",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "允许 Daily Todo 在足迹记录期间统计步数。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许 Daily Todo 选择任务图片。",
          "microphonePermission": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允许 Daily Todo 使用麦克风添加任务。",
          "speechRecognitionPermission": "允许 Daily Todo 将语音转换为任务文字。",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
